{
  "manifest_version": 3,
  "name": "Smart Tab Switcher",
  "version": "1.0.0",
  "description": "Alterna abas por ordem de uso recente com seletor visual estilo VSCode.",
  "permissions": ["tabs", "windows", "scripting", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Smart Tab Switcher"
  },
  "commands": {
    "quick-switch": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "Command+Q"
      },
      "description": "Trocar para a aba anterior (sem UI)"
    },
    "open-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Abrir lista de abas recentes"
    }
  }
}
